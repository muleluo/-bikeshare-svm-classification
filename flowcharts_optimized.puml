@startuml 整体实验流程
!theme plain
skinparam defaultFontName "Microsoft YaHei"
skinparam defaultFontSize 11
skinparam ArrowColor #2C3E50
skinparam BackgroundColor White
skinparam padding 2

title 实验整体流程

start

:原始数据集(662万条);

split
  :分层抽样\n按月比例抽样;
split again
  :数据清洗\n异常值处理;
end split

:特征工程\n时间+空间+行程(17个);

:数据标准化(Z-score);

split
  :训练集(80%);
split again
  :测试集(20%);
end split

:基线SVM训练;

:网格搜索\n5折交叉验证;

:最优模型;

split
  :模型评估\n准确率、混淆矩阵;
split again
  :结果分析\nROC/AUC;
end split

stop

@enduml


@startuml 数据清洗流程
!theme plain
skinparam defaultFontName "Microsoft YaHei"
skinparam defaultFontSize 10
skinparam ArrowColor #2C3E50
skinparam padding 2

title 数据清洗流程

start

:输入数据\n59,900条;

:步骤1: 缺失值处理\n删除关键字段缺失、填充非关键字段;
note right: 剩余59,827条

:步骤2: 时长异常检测\n删除<1分钟、删除>480分钟;
note right: 剩余58,381条

:步骤3: 距离异常检测\n删除>50公里;

:步骤4: 速度异常检测\n删除>40km/h;

:输出数据\n58,367条;
note right: 保留率97.44%

stop

@enduml


@startuml SVM算法流程
!theme plain
skinparam defaultFontName "Microsoft YaHei"
skinparam defaultFontSize 10
skinparam ArrowColor #E74C3C
skinparam ActivityBackgroundColor #ECF0F1
skinparam ActivityBorderColor #34495E
skinparam padding 2
skinparam nodesep 30
skinparam ranksep 30

title SVM分类算法流程

start

:输入训练数据\n{(x₁,y₁), ..., (xₙ,yₙ)};

partition "模型构建" {
  :核函数选择\nRBF核 / 线性核;

  :构建优化问题\nmin ½‖w‖² + C∑ξᵢ;

  :求解对偶问题\nmax ∑αᵢ - ½∑∑αᵢαⱼyᵢyⱼK(xᵢ,xⱼ);
}

partition "分类预测" {
  :识别支持向量\n(αᵢ > 0);

  :计算决策函数\nf(x) = sign(∑αᵢyᵢK(xᵢ,x) + b);

  :对新样本分类\ny_pred = f(x_new);
}

:输出分类模型;

stop

@enduml


@startuml 模型训练流程
!theme plain
skinparam defaultFontName "Microsoft YaHei"
skinparam defaultFontSize 10
skinparam ArrowColor #3498DB
skinparam ActivityBackgroundColor #EBF5FB
skinparam ActivityBorderColor #2874A6
skinparam padding 2

title 模型训练与优化流程

start

:输入特征矩阵\nX(58,367×17), y(58,367×1);

:数据标准化 X_scaled=(X-μ)/σ;

split
  :训练集80%;
split again
  :测试集20%;
end split

:基线模型训练\nSVM(C=1, γ=scale);

partition "超参数优化" #LightBlue {
  :参数网格\nC:[0.1,1,10]\nγ:['scale',0.01]\nkernel:['rbf','linear'];
  :5折交叉验证\n12组合×5折=60次;
  :选择最优参数;
}

:全训练集重新训练;

:测试集评估\n准确率、精确率、召回率\nF1、AUC、混淆矩阵;

:输出最优模型;

stop

@enduml


@startuml 交叉验证流程
!theme plain
skinparam defaultFontName "Microsoft YaHei"
skinparam defaultFontSize 10
skinparam ArrowColor #16A085
skinparam padding 2

title 5折交叉验证详细流程

start

:训练集\n46,693条;

:随机分5份\n每份≈9,339条;

fork
  :Fold 1\n训练→验证;
  :acc₁;
fork again
  :Fold 2\n训练→验证;
  :acc₂;
fork again
  :Fold 3\n训练→验证;
  :acc₃;
fork again
  :Fold 4\n训练→验证;
  :acc₄;
fork again
  :Fold 5\n训练→验证;
  :acc₅;
end fork

:计算平均准确率\navg=(acc₁+...+acc₅)/5;

:计算标准差\nstd;

:输出结果\navg_acc ± std;

stop

@enduml


@startuml 特征工程流程
!theme plain
skinparam defaultFontName "Microsoft YaHei"
skinparam defaultFontSize 9
skinparam ArrowColor #8E44AD
skinparam padding 2

title 特征工程流程

start

:输入清洗后数据;

note right
  **时间特征 (7个)**
  • hour - 出发小时(0-23)
  • day_of_week - 星期(0-6)
  • is_weekend - 是否周末
  • month_num - 月份(1-12)
  • time_period_* - 时段分类
    (早高峰/工作/晚高峰/其他)
  ----
  **空间特征 (4个)**
  • start_lat - 起点纬度
  • start_lng - 起点经度
  • end_lat - 终点纬度
  • end_lng - 终点经度
  ----
  **行程特征 (6个)**
  • trip_duration - 行程时长(分钟)
  • trip_distance - 行程距离(公里)
  • speed - 平均速度(km/h)
  • is_electric - 是否电动单车
  • is_round_trip - 是否往返
end note

:特征提取与计算\n时间解析 + 坐标处理 + 行程计算;

:合并所有特征\n总计 17 个特征变量;

:输出特征矩阵\nX (n × 17);

stop

@enduml
